# Auto-activation de l'env conda orderflowonfutures (direnv)
# Ajouté le 2026-06-10

CONDA_BASE=/Users/david.leconte/miniforge3
CONDA_ENV_PATH=/Users/david.leconte/Projects/FeynmanBasedResearch/OrderFlowOnFutures/.conda

# Source conda init
source "${CONDA_BASE}/etc/profile.d/conda.sh"

# Activer l'env orderflowonfutures
conda activate "${CONDA_ENV_PATH}"

# Workaround OpenMP (torch + libomp conflict sur macOS ARM)
export KMP_DUPLICATE_LIB_OK=TRUE
